# --- Application Configuration ---
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# --- Database & Redis ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=event_pilot_db

REDIS_HOST=localhost
REDIS_PORT=6379

# --- WhatsApp API (Meta) ---
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=eventpilot_token
WHATSAPP_PHONE_ID_DISPLAY=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_SIGNATURE=false

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Wave ---
WAVE_API_KEY=
WAVE_MONTHLY_AMOUNT=5000

# --- Security & JWT ---
JWT_SECRET=secret
ADMIN_API_KEY=admin

# --- Business Logic ---
PAYMENT_REGION=INTERNATIONAL
MONTHLY_PRICE_ID=price_default

# --- AI & LLM (Gemini) ---
GOOGLE_API_KEY=
GEMINI_MODEL_NAME=gemini-1.5-flash
AI_CONFIDENCE_THRESHOLD=0.85
