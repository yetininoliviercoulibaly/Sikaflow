# --- Application Configuration (STAGING) ---
NODE_ENV=staging
PORT=3000
# URL publique fournie par Cloudflare (ex: https://staging.votre-domaine.com)
APP_URL=https://staging.sikaflow.app

# --- Database & Redis (Docker internal) ---
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=secret_staging_password
DB_NAME=event_pilot_staging_db

REDIS_HOST=redis
REDIS_PORT=6379

# --- Cloudflare Tunnel ---
# Dashboard -> Zero Trust -> Access -> Tunnels
CLOUDFLARE_TUNNEL_TOKEN=

# --- WhatsApp API (Meta) - TEST NUMBER ---
# Utilisez le numéro de test fourni par Meta
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=sikaflow_staging_token
WHATSAPP_APP_SECRET=
# Mettre à 'false' pour tester avec curl sans signature valide
WHATSAPP_VERIFY_SIGNATURE=true

# --- Stripe (Test Mode) ---
# Clés commençant par sk_test_...
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Wave (Sandbox) ---
WAVE_API_KEY=

# --- Google Gemini AI ---
GOOGLE_API_KEY=
GEMINI_MODEL_NAME=gemini-1.5-flash
