# --- APP SETTINGS ---
NODE_ENV=production
PORT=3000
APP_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING

# --- DATABASE (PostgreSQL) ---
# For All-in-One (Internal Docker Network)
# DB_HOST=db
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_secure_db_password
# DB_NAME=event_pilot_db

# For Hybrid (Supabase)
# DB_HOST=aws-0-eu-central-1.pooler.supabase.com
# DB_PORT=6543
# DB_USER=postgres.youruser
# DB_PASSWORD=your_supabase_password
# DB_NAME=postgres

# --- REDIS (Queue & Cache) ---
# For All-in-One (Internal Docker Network)
# REDIS_HOST=redis
# REDIS_PORT=6379

# For Hybrid (Upstash)
# REDIS_HOST=wealthy-mole-32145.upstash.io
# REDIS_PORT=6379
# REDIS_PASSWORD=your_upstash_password
# REDIS_TLS=true

# --- CLOUDFLARE TUNNEL ---
CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoi...

# --- WHATSAPP API ---
WHATSAPP_API_TOKEN=EAAG...
WHATSAPP_PHONE_NUMBER_ID=123456...
