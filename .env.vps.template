# ============================================================================
# SIKAFLOW - TEMPLATE .ENV POUR VPS
# ============================================================================
# Ce fichier doit être placé dans ~/sikaflow/.env sur votre VPS
# Remplacez toutes les valeurs entre <CROCHETS> par vos vraies valeurs
# ============================================================================

# ============================================================================
# 1. CONFIGURATION DOCKER / GITHUB
# ============================================================================
# Votre nom d'utilisateur GitHub (pour GHCR)
GITHUB_REPOSITORY_OWNER=<votre-username-github>

# ============================================================================
# 2. BASE DE DONNÉES (PostgreSQL)
# ============================================================================
DB_HOST=db
DB_PORT=5432
DB_USER=sikaflow
DB_PASSWORD=<changez-moi-mot-de-passe-tres-securise>
DB_NAME=sikaflow_staging
# Pour production, utilisez : DB_NAME=sikaflow_prod

# ============================================================================
# 3. CACHE (Redis)
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================================================
# 4. APPLICATION
# ============================================================================
NODE_ENV=staging
# Pour production, utilisez : NODE_ENV=production

PORT=3000
APP_URL=https://staging.sikaflow.com
# Pour production : APP_URL=https://sikaflow.com

# ============================================================================
# 5. WHATSAPP CLOUD API
# ============================================================================
# Récupérez ces valeurs depuis Meta for Developers
# https://developers.facebook.com/apps/
WHATSAPP_PHONE_NUMBER_ID=<votre-phone-number-id>
WHATSAPP_ACCESS_TOKEN=<votre-access-token>
WHATSAPP_VERIFY_TOKEN=<votre-verify-token>

# ============================================================================
# 6. STRIPE (Paiements)
# ============================================================================
# Récupérez ces valeurs depuis Stripe Dashboard
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=<sk_test_ou_sk_live_xxxxxxxxxx>
STRIPE_WEBHOOK_SECRET=<whsec_xxxxxxxxxx>

# ============================================================================
# 7. WAVE (Paiements Mobile Money)
# ============================================================================
# Récupérez cette valeur depuis Wave Dashboard
WAVE_API_KEY=<wave_xxxxxxxxxx>

# ============================================================================
# 8. SÉCURITÉ / AUTHENTIFICATION
# ============================================================================
# Clé secrète pour JWT (générez une chaîne aléatoire longue)
# Vous pouvez générer avec: openssl rand -base64 32
JWT_SECRET=<votre-jwt-secret-super-securise>

# Clé API Admin (pour accès admin)
ADMIN_API_KEY=<votre-api-key-admin>

# ============================================================================
# 9. FRONTEND (Next.js)
# ============================================================================
# URL de l'API backend (doit correspondre à APP_URL)
NEXT_PUBLIC_API_URL=https://staging.sikaflow.com
# Pour production : NEXT_PUBLIC_API_URL=https://sikaflow.com

# ============================================================================
# 10. CLOUDFLARE TUNNEL
# ============================================================================
# Token du tunnel Cloudflare
# Créez votre tunnel sur : https://one.dash.cloudflare.com/
CLOUDFLARE_TUNNEL_TOKEN=<eyJhIjoixxxxxxxxxx>

# ============================================================================
# 11. MIKRO-ORM (Base de données ORM)
# ============================================================================
MIKRO_ORM_MIGRATIONS_DISABLE_FOREIGN_KEYS=false

# ============================================================================
# 12. TELEGRAM BOT API
# ============================================================================
# Create your bot via @BotFather on Telegram
# https://core.telegram.org/bots#creating-a-new-bot
TELEGRAM_BOT_TOKEN=<your-bot-token>
TELEGRAM_WEBHOOK_SECRET=<your-webhook-secret>
TELEGRAM_BOT_USERNAME=SikaFlowBot
# Optional: Skip signature verification (NOT recommended)
# TELEGRAM_VERIFY_SIGNATURE=false

# ============================================================================
# NOTES IMPORTANTES
# ============================================================================
# - Ne JAMAIS commiter ce fichier dans Git
# - Gardez une copie backup sécurisée de ce fichier
# - Pour staging, utilisez les clés de test (Stripe sk_test_*, etc.)
# - Pour production, utilisez les clés live (Stripe sk_live_*, etc.)
# - Changez JWT_SECRET entre staging et production
# - Le CLOUDFLARE_TUNNEL_TOKEN est différent pour staging et production
# ============================================================================

